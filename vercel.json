{
  "version": 2,
  "buildCommand": "pnpm build",
  "outputDirectory": "dist",
  "env": {
    "NODE_ENV": "production"
  },
  "functions": {
    "api/**/*.ts": {
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "routes": [
    {
      "src": "/api/trpc(.*)",
      "dest": "/api/trpc.ts"
    },
    {
      "src": "/api/oauth(.*)",
      "dest": "/api/oauth.ts"
    },
    {
      "src": "/api/chat(.*)",
      "dest": "/api/chat.ts"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
